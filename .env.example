# Auth.js v5 Configuration
# AUTH_SECRET is the v5 canonical name; NEXTAUTH_SECRET also works.
AUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_URL is auto-inferred in Vercel; set manually for local dev
# NEXTAUTH_URL=http://localhost:3000

# Demo Mode - Set to true to log magic links instead of sending emails
DEMO_MODE=true

# Admin Email(s) - Comma separated
ADMIN_EMAILS=your-email@example.com

# Allowed sign-in email — the single email address permitted to authenticate
ALLOWED_EMAIL=your-email@example.com

# Email Configuration (only needed if DEMO_MODE=false)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# PostgreSQL Database (optional — falls back to local JSON adapter if unset)
# Required for production auth persistence. Neon example shown below.
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Set to "false" only for Neon free-tier (shared TLS cert doesn't match hostname).
# Omit or leave unset for any other provider to keep full certificate verification.
DB_SSL_REJECT_UNAUTHORIZED=false